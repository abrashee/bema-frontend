{
  "name": "bema-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest --config jest.config.cjs",
    "e2e": "playwright test",
    "build:stats": "ng build --stats-json",
    "analyze:bundle": "npm run build:stats && node scripts/analyze-bundle.cjs",
    "serve:dist": "http-server dist/bema-frontend/browser -p 4173",
    "lighthouse": "lighthouse http://localhost:4173 --chrome-flags=\"--headless\" --output=json --output-path=lighthouse-report.json",
    "ci:lighthouse": "start-server-and-test serve:dist http://127.0.0.1:4173 \"lighthouse http://127.0.0.1:4173 --chrome-flags=\\\"--headless --no-sandbox\\\" --output=json --output-path=lighthouse-report.json && npm run check:lighthouse\"",
    "check:lighthouse": "node scripts/check-lighthouse.cjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.26",
    "@angular/cdk": "^20.2.8",
    "@angular/common": "20.3.26",
    "@angular/compiler": "20.3.26",
    "@angular/core": "20.3.26",
    "@angular/forms": "20.3.26",
    "@angular/material": "^20.2.8",
    "@angular/platform-browser": "20.3.26",
    "@angular/router": "20.3.26",
    "rxjs": "~7.8.0",
    "socket.io-client": "4.8.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "20.3.32",
    "@angular/cli": "20.3.32",
    "@angular/compiler-cli": "20.3.26",
    "@playwright/test": "^1.61.0",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.28.0",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^17.0.0",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.0",
    "start-server-and-test": "^3.0.11",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "engine": {
      "io-client": "6.6.6"
    },
    "ws": "8.21.0",
    "socket.io-client": {
      "engine.io-client": "6.6.6"
    },
    "engine.io-client": {
      "ws": "8.21.0"
    }
  },
  "license": "MIT"
}
